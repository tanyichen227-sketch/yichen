# ================================================================
# KnowledgeRAG-GZHU Backend Environment Configuration
# ================================================================
# INSTRUCTIONS:
#   1. Copy this file to .env in the same directory:
#         cp .env.example .env     (Linux/macOS)
#         copy .env.example .env   (Windows)
#   2. Fill in your own values below.
#   3. Never commit .env to git — it is listed in .gitignore.
# ================================================================

# ── MySQL Database ──────────────────────────────────────────────
DB_HOST=127.0.0.1
# If you use this repo's docker-compose mysql service, host port is 3307.
DB_PORT=3307
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here
DB_NAME=rag_user_db
DB_CHARSET=utf8mb4

# ── JWT Secret ──────────────────────────────────────────────────
# Use a long random string; openssl rand -hex 32 works well.
JWT_SECRET=change_me_to_a_long_random_string

# ── Ollama (local LLM) ──────────────────────────────────────────
# Default: http://localhost:11434
# Recommended model for low-memory machines: qwen2:0.5b (~600MB)
OLLAMA_BASE_URL=http://localhost:11434
MODEL=qwen2:0.5b

# ── Email (SMTP) — optional ─────────────────────────────────────
# If not configured, feedback falls back to mailto: in the browser.
# SMTP_USER=your_email@163.com
# SMTP_PASS=your_163_smtp_auth_code
SMTP_HOST=smtp.163.com
SMTP_PORT=465

# ── Aliyun OSS — optional ───────────────────────────────────────
# Only needed if you want cloud file storage.
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY=your_access_key
# OSS_SECRET_KEY=your_secret_key
# OSS_BUCKET=your_bucket_name
# OSS_PREFIX=
