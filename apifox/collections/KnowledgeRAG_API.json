    "/metrics": {
      "get": {
        "tags": ["系统监控"],
        "summary": "Prometheus 指标",
        "description": "返回 Prometheus 格式的系统指标，可接入 Grafana 大盘。",
        "security": [],
        "responses": {
          "200": {
            "description": "Prometheus text format 指标",
            "content": {
              "text/plain": {
                "example": "# HELP http_requests_total 总请求数\nhttp_requests_total{method=\"POST\",endpoint=\"/api/RAG/RAG_query\"} 42"
              }
            }
          }
        }
      }
    }
  }
