          "200": { "description": "当前用户保存的模型配置" }
        }
      },
      "post": {
        "tags": ["用户设置"],
        "summary": "保存用户模型配置",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "llm_model": "deepseek-chat",
