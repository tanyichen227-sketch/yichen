                "ollama_timeout": 120,
                "embedding_model": "moka-ai/m3e-base"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "配置保存成功" }
        }
      }
    },
    "/api/audit/logs": {
      "get": {
        "tags": ["审计日志"],
        "summary": "查询 API 调用记录",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "path", "in": "query", "schema": { "type": "string" }, "description": "过滤接口路径" }
        ],
        "responses": {
          "200": { "description": "审计日志列表" }
        }
      }
