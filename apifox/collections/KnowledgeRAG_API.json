          { "name": "share_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": { "owner_id": "test@rag-gzhu.com" }
            }
          }
        },
        "responses": {
          "200": { "description": "收藏状态切换成功" }
        }
      }
    },
    "/api/creation/generate": {
      "post": {
        "tags": ["文档创作"],
        "summary": "[SSE] 文档创作",
        "description": "5 种创作模式，**流式返回**生成内容：\n\n| mode | 说明 |\n|------|------|\n| `summary` | 摘要提炼 |\n| `translate` | 翻译（指定 target_lang）|\n| `outline` | 生成大纲 |\n| `optimize` | 语言优化 |\n| `expand` | 内容扩写 |",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "mode": "summary",
                "content": "这是一段需要处理的文本内容...",
                "model": "deepseek-chat",
                "target_lang": "en",
                "extra": {}
              }
            }
          }
        },
        "responses": {
          "200": { "description": "SSE 创作内容流" }
        }
      }
    },
    "/api/eval/run": {
      "post": {
        "tags": ["模型评测"],
        "summary": "运行 RAG 效果评测",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "kb_id": "kb_abc123",
                "model": "deepseek-chat",
                "metrics": ["faithfulness", "relevancy", "context_recall"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "评测已提交，返回 run_id" }
        }
      }
    },
    "/api/eval/results": {
      "get": {
        "tags": ["模型评测"],
        "summary": "获取评测结果列表",
        "responses": {
          "200": { "description": "历史评测结果，含雷达图 / 柱状图数据" }
        }
      }
    },
    "/api/user/profile": {
      "get": {
        "tags": ["用户设置"],
        "summary": "获取用户信息",
        "responses": {
          "200": {
            "description": "用户信息",
            "content": {
              "application/json": {
                "example": {
                  "email": "test@rag-gzhu.com",
                  "name": "测试用户",
                  "signature": "这个人很懒，什么也没写",
                  "avatar": "https://..."
                }
              }
            }
          }
        }
      }
    },
    "/api/user/model-config": {
      "get": {
        "tags": ["用户设置"],
        "summary": "获取用户模型配置",
