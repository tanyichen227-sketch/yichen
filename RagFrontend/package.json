{
  "name": "asf-rag",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src --ext .vue,.js,.ts",
    "lint:fix": "eslint src --ext .vue,.js,.ts --fix",
    "format": "prettier --write src/**/*.{vue,js,ts}",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "precommit": "lint-staged"
  },
  "lint-staged": {
    "_.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "_.{css,scss,less}": [
      "stylelint --fix",
      "prettier --write"
    ],
    ".{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tdesign-vue-next/chat": "^0.4.3",
    "axios": "^1.11.0",
    "chroma-js": "^3.1.2",
    "d3": "^7.9.0",
    "dompurify": "^3.2.6",
    "graphology": "^0.26.0",
    "graphology-layout": "^0.6.1",
    "graphology-layout-force": "^0.2.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "highlight.js": "^11.11.1",
    "marked": "^16.1.1",
    "pinia": "^3.0.3",
    "quasar": "^2.18.2",
    "sigma": "^3.0.2",
    "tdesign-icons-vue-next": "latest",
    "tdesign-vue-next": "latest",
    "tvision-color": "^1.6.0",
    "uuid": "^11.1.0",
    "vite-svg-loader": "^5.1.0",
    "vue": "^3.4.21",
    "vue-router": "^4.5.1",
    "vue-typewriter-effect": "^1.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.32.0",
    "@types/chroma-js": "^3.1.1",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jiti": "^2.5.1",
    "less": "^4.4.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.4.4",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.2.8",
    "vite-plugin-vue-devtools": "^7.7.7",
    "vue-tsc": "^2.0.10"
  },
  "description": "RAG-F 智能知识库系统",
  "main": "postcss.config.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/March030303/KnowledgeRAG.git"
